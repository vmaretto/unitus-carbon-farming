{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300,
        "memory": 1024,
        "includeFiles": "db/migrations/**"
      }
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api(?:/(.*))?", "dest": "/api/index.js" },
    { "src": "/share(?:/(.*))?", "dest": "/api/index.js" },
    { "src": "/sitemap\\.xml", "dest": "/api/index.js" },
    { "src": "/sitemap", "dest": "/api/index.js" },
    { "src": "/robots\\.txt", "dest": "/api/index.js" },
    { "src": "/([a-f0-9]{8,128})\\.txt", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/", "dest": "/index.html" }
  ]
}
